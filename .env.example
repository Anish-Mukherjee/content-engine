# Postgres
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/content_pipeline

# Server
PORT=4000
LOG_LEVEL=info

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Perplexity
PERPLEXITY_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Unsplash (hero images)
UNSPLASH_ACCESS_KEY=

# Inline image sources. The orchestrator queries every configured source per
# placeholder query and lets pickUniqueInline pick the first non-duplicate hit.
# Order: Freepik → Wikimedia (keyless) → Pixabay → Pexels → Unsplash.
FREEPIK_API_KEY=
PIXABAY_API_KEY=
PEXELS_API_KEY=

# Google Indexing (path to service account JSON; file not committed)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./google-service-account.json

# Frontend (xerogravity.com) integration
FRONTEND_BASE_URL=https://xerogravity.com
FRONTEND_REVALIDATE_SECRET=

# Admin API (for future admin dash)
ADMIN_API_KEY=

# Alerting (optional)
WEBHOOK_URL=

# Scheduler controls
# Single UTC hour (0-23) at which all daily articles publish.
PUBLISH_HOUR_UTC=3
# How many articles drive + publish per UTC day. All publish at PUBLISH_HOUR_UTC
# as a batch. Bounded 1-20 by the env validator.
ARTICLES_PER_DAY=2
DISABLE_CRON=false
