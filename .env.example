# Postgres
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/content_pipeline

# Server
PORT=4000
LOG_LEVEL=info

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Perplexity
PERPLEXITY_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Unsplash (hero images)
UNSPLASH_ACCESS_KEY=

# Inline images come from Openverse (anonymous, no key needed) with Wikimedia
# Commons as a fallback. Both are free and keyless. Google Programmable Search
# whole-web is deprecated as of March 2026.

# Google Indexing (path to service account JSON; file not committed)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./google-service-account.json

# Frontend (xerogravity.com) integration
FRONTEND_BASE_URL=https://xerogravity.com
FRONTEND_REVALIDATE_SECRET=

# Admin API (for future admin dash)
ADMIN_API_KEY=

# Alerting (optional)
WEBHOOK_URL=

# Scheduler controls
PUBLISH_HOUR_UTC=9
DISABLE_CRON=false
